# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/emo_here
POSTGRES_USER=emo_user
POSTGRES_PASSWORD=emo_password
POSTGRES_DB=emo_here

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Kakao
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_APP_KEY=your-kakao-app-key

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=emo-here-uploads

# Application
APP_NAME=이모~여기!
APP_VERSION=0.1.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# SMS (for phone verification)
SMS_API_KEY=your-sms-api-key
SMS_SENDER=01012345678
